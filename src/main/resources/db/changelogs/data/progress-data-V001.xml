<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-insert-progress-data-v001" author="Hromov">
        <preConditions onFail="HALT">
            <and>
                <tableExists schemaName="dbo" tableName="progress"/>
                <tableExists schemaName="dbo" tableName="user"/>
                <tableExists schemaName="dbo" tableName="task"/>
                <columnExists schemaName="dbo" tableName="progress" columnName="user_id"/>
                <columnExists schemaName="dbo" tableName="progress" columnName="task_id"/>
            </and>
        </preConditions>

        <sql>
            INSERT INTO dbo.progress (user_id, task_id) VALUES
                (1, 1),  (2, 1),  (3, 2),
                (4, 3),  (5, 3),  (6, 4),
                (7, 5),  (8, 6),  (9, 7),
                (10, 8), (11, 9), (12, 10),
                (13, 11), (14, 12), (15, 13);
        </sql>

        <rollback>
            <sql>
                DELETE FROM dbo.progress
                WHERE user_id BETWEEN 1 AND 15;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>