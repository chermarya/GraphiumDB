<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="037-add-video-url-to-lesson" author="shvets">
        <preConditions onFail="HALT">
            <tableExists schemaName="dbo" tableName="lesson"/>
        </preConditions>

        <addColumn tableName="lesson">
            <column name="video_url" type="VARCHAR(500)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="lesson" columnName="video_url"/>
        </rollback>
    </changeSet>

</databaseChangeLog>