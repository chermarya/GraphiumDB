<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="040-add-graph-count-to-projects" author="Hromov">
        <addColumn tableName="projects">
            <column name="graph_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <sql>
            UPDATE [liquibase_lab].[dbo].[tables]
            SET column_count = 3,
                last_update_at = GETDATE()
            WHERE name = 'projects' AND author = 'Hromov';

        </sql>

        <rollback>
            <dropColumn tableName="user" columnName="graph_count"/>
        </rollback>
    </changeSet>

</databaseChangeLog>