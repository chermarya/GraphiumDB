<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="042-drop-progress-table" author="Hromov">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="progress"/>
        </preConditions>

        <dropTable tableName="progress"/>

        <rollback>
            <createTable tableName="progress">
                <column name="user_id" type="BIGINT">
                    <constraints nullable="false"
                                 foreignKeyName="fk_progress_user"
                                 referencedTableName="user"
                                 referencedColumnNames="user_id"/>
                </column>
                <column name="task_id" type="BIGINT">
                    <constraints nullable="false"
                                 foreignKeyName="fk_progress_task"
                                 referencedTableName="task"
                                 referencedColumnNames="task_id"/>
                </column>
                <column name="last_visited" type="DATETIME"/>
            </createTable>
        </rollback>
    </changeSet>

</databaseChangeLog>