<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="038-add-last-visited-to-progress" author="shvets">
        <preConditions onFail="HALT">
            <tableExists schemaName="dbo" tableName="progress"/>
        </preConditions>

        <addColumn tableName="progress">
            <column name="last_visited" type="DATETIME"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="progress" columnName="last_visited"/>
        </rollback>
    </changeSet>

</databaseChangeLog>