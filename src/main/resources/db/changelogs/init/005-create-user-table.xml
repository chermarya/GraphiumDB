<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-create-user-table" author="hromov" >
        <createTable tableName="user">
            <column name="user_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_user"/>
            </column>

            <column name="nickname" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="surname" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="registration_date" type="DATETIME" defaultValueComputed="SYSUTCDATETIME()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="user" indexName="idx_user_email">
            <column name="email"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'user', 'DATA_TABLE', 'Hromov', 1, 'USER_SERVICE',
                    'Table for storing user accounts and credentials',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('user')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'user';</sql>
            <dropTable tableName="user"/>
        </rollback>
    </changeSet>

</databaseChangeLog>