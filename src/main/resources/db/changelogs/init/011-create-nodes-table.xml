<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="008-create-nodes-table" author="Khapal">
        <createTable tableName="nodes">
            <column name="node_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_nodes"/>
            </column>

            <column name="graph_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_nodes_graph"
                             referencedTableName="graph"
                             referencedColumnNames="graph_id"/>
            </column>

            <column name="name" type="VARCHAR(255)"/>
            <column name="pos_x" type="FLOAT"/>
            <column name="pos_y" type="FLOAT"/>
            <column name="color" type="VARCHAR(50)"/>
        </createTable>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'nodes', 'DATA_TABLE', 'khapal', 1, 'graph_structure_service',
                    'Table for storing graph nodes.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('nodes')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <dropTable tableName="nodes"/>
            <sql>DELETE FROM dbo.tables WHERE name = 'nodes';</sql>
        </rollback>

    </changeSet>
</databaseChangeLog>