<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-create-projects-table" author="Hromov">
        <createTable tableName="projects">
            <column name="project_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_projects_user"
                             referencedTableName="user"
                             referencedColumnNames="user_id"/>
            </column>
            <column name="created_at" type="DATETIME" defaultValueComputed="SYSUTCDATETIME()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="DATETIME" defaultValueComputed="SYSUTCDATETIME()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="projects" indexName="idx_projects_user_id">
            <column name="user_id"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'projects', 'DATA_TABLE', 'Hromov', 1, 'USER_SERVICE',
                    'Table for storing information about user projects',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('projects')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'projects';</sql>
            <dropTable tableName="projects"/>
        </rollback>
    </changeSet>

</databaseChangeLog>