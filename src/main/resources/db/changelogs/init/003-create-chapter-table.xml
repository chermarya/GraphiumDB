<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-chapter-table" author="shvets">
        <createTable tableName="chapter">
            <column name="chapter_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="lesson_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_chapter_lesson"
                             referencedTableName="lesson"
                             referencedColumnNames="lesson_id"/>
            </column>

            <column name="number" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="text" type="VARCHAR(MAX)"/>
        </createTable>

        <createIndex tableName="chapter" indexName="idx_chapter_lesson_id">
            <column name="lesson_id"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'chapter', 'DATA_TABLE', 'shvets', 1, 'education_service',
                    'Table for storing chapter records.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('chapter')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'chapter';</sql>
            <dropIndex indexName="idx_chapter_lesson_id" tableName="chapter"/>
            <dropTable tableName="chapter"/>
        </rollback>
    </changeSet>

</databaseChangeLog>