<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-lesson-table" author="shvets">
        <createTable tableName="lesson">
            <column name="lesson_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(1000)"/>
        </createTable>

        <createIndex tableName="lesson" indexName="idx_lesson_title">
            <column name="title"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'lesson', 'DATA_TABLE', 'shvets', 1, 'education_service',
                    'Table for storing lesson records.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('lesson')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'lesson';</sql>
            <dropIndex indexName="idx_lesson_title" tableName="lesson"/>
            <dropTable tableName="lesson"/>
        </rollback>
    </changeSet>

</databaseChangeLog>