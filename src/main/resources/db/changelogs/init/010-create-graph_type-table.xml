<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="010-create-graph_type-table" author="cherevko">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="graph_type"/>
            </not>
        </preConditions>

        <createTable tableName="graph_type">
            <column name="graph_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_graph_type_graph"
                             referencedTableName="graph"
                             referencedColumnNames="graph_id"/>
            </column>
            <column name="type_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_graph_type_types"
                             referencedTableName="types"
                             referencedColumnNames="type_id"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="graph_type"
                       columnNames="graph_id, type_id"
                       constraintName="pk_graph_type"/>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'graph_type', 'DATA_TABLE', 'cherevko', 1, 'graph_service',
                    'Intermediate table for implementing many-to-many relationship.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('graph_type')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <dropTable tableName="graph_type"/>
            <sql>DELETE FROM dbo.tables WHERE name = 'graph_type';</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
