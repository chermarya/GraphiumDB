<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-task-table" author="shvets">
        <createTable tableName="task">
            <column name="task_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="chapter_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_task_chapter"
                             referencedTableName="chapter"
                             referencedColumnNames="chapter_id"/>
            </column>

            <column name="text" type="VARCHAR(MAX)">
                <constraints nullable="false"/>
            </column>

            <column name="solution" type="VARCHAR(MAX)"/>
        </createTable>

        <createIndex tableName="task" indexName="idx_task_chapter_id">
            <column name="chapter_id"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'task', 'DATA_TABLE', 'shvets', 1, 'education_service',
                    'Table for storing task records.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('task')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'task';</sql>
            <dropIndex indexName="idx_task_chapter_id" tableName="task"/>
            <dropTable tableName="task"/>
        </rollback>
    </changeSet>

</databaseChangeLog>