<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-create-types-table" author="cherevko">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="types"/>
            </not>
        </preConditions>

        <createTable tableName="types">
            <column name="type_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'types', 'DATA_TABLE', 'cherevko', 1, 'graph_service',
                    'Table for storing info about graph types.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('types')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <dropTable tableName="types"/>
            <sql>DELETE FROM dbo.tables WHERE name = 'types';</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
